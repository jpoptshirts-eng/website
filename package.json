{
  "name": "jacinto-portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "kill-port": "lsof -ti:3000 | xargs kill -9 2>/dev/null || true",
    "dev": "npm run kill-port && next dev -p 3000",
    "dev:clean": "npm run kill-port && rm -rf .next && next dev -p 3000",
    "build": "next build",
    "start": "npm run kill-port && next start -p 3000",
    "serve": "npm run kill-port && npm run build && next start -p 3000",
    "lint": "next lint"
  },
  "dependencies": {
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.511.0",
    "next": "^15.3.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.2",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
